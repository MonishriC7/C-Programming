#include <vector>
#include <string>
#include <unordered_map>

using namespace std;

class Solution {
public:
    vector<int> findSubstring(string s, vector<string>& words) {
        vector<int> result;
        if (s.empty() || words.empty()) return result;

        int wordLen = words[0].length();
        int wordCount = words.size();
        int totalLen = wordLen * wordCount;
        int sLen = s.length();

        unordered_map<string, int> wordFreq;
        for (const string& word : words) {
            wordFreq[word]++;
        }

        // We only need to check 'wordLen' different starting offsets
        for (int i = 0; i < wordLen; ++i) {
            int left = i, right = i, count = 0;
            unordered_map<string, int> windowFreq;

            while (right + wordLen <= sLen) {
                string word = s.substr(right, wordLen);
                right += wordLen;

                if (wordFreq.count(word)) {
                    windowFreq[word]++;
                    count++;

                    // If a word appears more times than needed, shrink from the left
                    while (windowFreq[word] > wordFreq[word]) {
                        string leftWord = s.substr(left, wordLen);
                        windowFreq[leftWord]--;
                        count--;
                        left += wordLen;
                    }

                    // If window size matches total required length, add to result
                    if (count == wordCount) {
                        result.push_back(left);
                    }
                } else {
                    // Reset window if an invalid word is encountered
                    windowFreq.clear();
                    count = 0;
                    left = right;
                }
            }
        }
        return result;
    }
};
